{
    "artists": {
        "Francis Johnson": {
            "bio": "Francis Johnson (1792-1844) was the first Black American to publish sheet music. Based in Philadelphia, he led one of the most popular dance bands in the country and was the first American musician to tour Europe. He composed over 200 works including marches, cotillions, and waltzes.",
            "years": "1792-1844",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Frank_Johnson.jpg/250px-Frank_Johnson.jpg"
        },
        "Francis Hopkinson": {
            "bio": "Francis Hopkinson (1737-1791) was a signer of the Declaration of Independence and the first American-born composer. He designed the first American flag, served as a federal judge, and wrote 'My Days Have Been So Wondrous Free,' considered the first secular song by an American.",
            "years": "1737-1791",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/2/2e/Francis_Hopkinson.jpg/250px-Francis_Hopkinson.jpg"
        },
        "Johann Frederich Peter": {
            "bio": "Johann Friedrich Peter (1746-1813) was a Moravian composer who wrote the first chamber music composed in America. Born in the Netherlands, he came to Pennsylvania and North Carolina, composing sacred anthems and string quintets that blended European classical style with American spirit.",
            "years": "1746-1813",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg/250px-Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg"
        },
        "John Christopher Moller": {
            "bio": "John Christopher Moller (c.1755-1803) was a German-born composer and organist who settled in Philadelphia and New York. He co-founded one of America's first music publishing firms and organized some of the earliest public concerts in the new nation.",
            "years": "c.1755-1803",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg/250px-Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg"
        },
        "Joseph Gehot": {
            "bio": "Joseph Gehot (c.1756-c.1820) was a Belgian-born violinist and composer who immigrated to America around 1792. He performed in New York and Philadelphia and composed chamber music in the European classical style for American audiences.",
            "years": "c.1756-c.1820",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg/250px-Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg"
        },
        "Isaac Hazzard": {
            "bio": "Isaac Hazzard was a Black American musician and composer in early 19th-century Philadelphia. He played in Francis Johnson's celebrated band and composed dance music including quadrilles, waltzes, and quicksteps.",
            "years": "early 1800s",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg/250px-Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg"
        },
        "A. J. R. Conner": {
            "bio": "A. J. R. Conner was an American composer and musician active in the 1840s-1850s, known for dance music including polkas, waltzes, and cotillions popular in Philadelphia ballrooms.",
            "years": "1840s-1850s",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg/250px-Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg"
        },
        "James Hemmenway": {
            "bio": "James Hemmenway was a Black American musician in early 19th-century Philadelphia who played in Francis Johnson's band. He composed marches and dance music, including pieces honoring the Marquis de Lafayette's 1824 American tour.",
            "years": "early 1800s",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg/250px-Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg"
        },
        "Edward Roland": {
            "bio": "Edward Roland was an American composer active in the mid-1800s, known for dance music performed in Philadelphia's social halls.",
            "years": "mid 1800s",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg/250px-Frank_Johnson_piano_manuscript%2C_1820._The_Library_Company_of_Philadelphia.jpg"
        },
        "U.S. Army Band": {
            "bio": "The United States Army Band ('Pershing's Own') is the premier musical organization of the U.S. Army, performing at state functions and public concerts since 1922. Their recordings of patriotic music are in the public domain.",
            "years": "est. 1922",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/3/38/US_Army_Band_DUI.PNG"
        },
        "William Billings": {
            "bio": "William Billings (1746-1800) was America's first major choral composer. A Boston tanner by trade, he wrote 'Chester,' which became the unofficial anthem of the American Revolution, sung by Continental Army soldiers.",
            "years": "1746-1800",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/9/93/1781_PsalmSingersAmusement_byWilliamBillings_Boston.jpg/250px-1781_PsalmSingersAmusement_byWilliamBillings_Boston.jpg"
        },
        "Traditional": {
            "bio": "Traditional American songs passed down through oral tradition, reflecting the political and cultural life of the Early Republic.",
            "years": "",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/9/98/Willard_Spirit_of_76_original_version.jpg/250px-Willard_Spirit_of_76_original_version.jpg"
        },
        "Pyotr Tchaikovsky": {
            "bio": "Pyotr Ilyich Tchaikovsky (1840-1893) was a Russian composer. His '1812 Overture' commemorates Russia's defense against Napoleon in 1812, the same year the United States fought the War of 1812 against Britain.",
            "years": "1840-1893",
            "portrait": "https://upload.wikimedia.org/wikipedia/commons/thumb/2/20/Tchaikovsky_by_Reutlinger_%28cropped%29.jpg/250px-Tchaikovsky_by_Reutlinger_%28cropped%29.jpg"
        }
